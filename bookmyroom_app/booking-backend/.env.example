# Copy this file to .env and fill in real values for your machine.
# The .env file is gitignored -- never commit real secrets.

# Port the Express server listens on.
PORT=4001

# MongoDB connection string. For MongoDB Atlas the format is:
#   mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<db>?appName=<name>
# For a local mongod instance use:
#   mongodb://127.0.0.1:27017/bookmyroom
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/bookmyroom?appName=Cluster0

# Long random string used to sign JWT auth tokens. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-me-with-a-long-random-string

# Origin the browser will send API requests from. CORS is locked to this
# single value in src/index.ts -- keep it in sync with the frontend's
# Vite dev-server port (see booking-frontend/vite.config.ts).
CLIENT_URL=http://localhost:3002

# Mail settings for OTP delivery (Lesson 21.1).
# Mailtrap Sandbox is captured -- messages never reach real inboxes, so it's
# safe for local development. Get your own credentials from your Mailtrap
# sandbox inbox settings at https://mailtrap.io/inboxes -- don't commit real
# values to git.
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=587
MAIL_SECURE=false
SMTP_USERNAME=<your mailtrap sandbox username>
SMTP_PASSWORD=<your mailtrap sandbox password>
SMTP_DEFAULT_FROM=no-reply@bookmyroom.example

# Payment integration (Lesson 26).
# EPAYTEST / 8gBm/:&EnhH.1/q are eSewa's official sandbox credentials --
# publicly documented and safe for local development. Swap to real
# merchant values for production.
ESEWA_MERCHANT_ID=EPAYTEST
ESEWA_SECRET_KEY=8gBm/:&EnhH.1/q
ESEWA_TEST_MODE=true

# The URL eSewa hits with its success / failure redirects. Must be a
# publicly reachable HTTPS origin in production. Localhost only works
# in dev because the guest's browser is on the same machine.
SERVER_BASE_URL=http://localhost:4001

# Cron: reclaim abandoned eSewa bookings (Lesson 26.14). See docs on
# tuning down (e.g. 1-minute window + every-minute cadence) for demos.
ABANDONED_BOOKING_MINUTES=30
ABANDONED_BOOKING_CRON=*/5 * * * *
