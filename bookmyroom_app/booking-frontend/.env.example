# Copy this file to .env and adjust the values for your machine.
#
# Vite exposes any variable prefixed with VITE_ to the browser via
# import.meta.env, so keep sensitive keys (Stripe secrets, etc.) OUT of
# this file -- they belong in the backend only.

# Base URL of the Express API. The frontend talks to the backend through
# this URL (see src/services/api.ts).
VITE_API_URL=http://localhost:4001/api
